#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=01

APP_DIR="/opt/scubaaaa-api"

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/python3 -m uvicorn app.main:app \
        --host 0.0.0.0 --port 8000
    procd_set_param env "PYTHONPATH=$APP_DIR"
    procd_set_param dir "$APP_DIR"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 0
    procd_close_instance
}
